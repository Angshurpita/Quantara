# ──────────────────────────────────────────────────────────────────────
# Quantara — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────────────────────────────

# ──── Frontend (Vite) ────────────────────────────────────────────────
# Firebase Configuration (from Firebase Console → Project Settings → Web App)
VITE_FIREBASE_API_KEY=your-api-key-here
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef

# Backend API URL (for CSV analysis)
VITE_API_URL=http://localhost:1000

# ──── Backend ─────────────────────────────────────────────────────────
# JWT Secret Key — REQUIRED in production. Generate a strong random key.
JWT_SECRET_KEY=your-secure-random-secret-key-here

# For Firebase Admin token verification, place a service-account.json 
# in the backend/ directory, or set GOOGLE_APPLICATION_CREDENTIALS.
# GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
